# CAD toolchain venv (recreate: python3.12 -m venv .venv && .venv/bin/pip install ezdxf cadquery matplotlib)
.venv/
__pycache__/

# scratch render artifacts (underscore-prefixed, per repo convention)
out/_*
out/*.svg

# The manufacturing package in out/ (STEP + DXF + PDF) IS the deliverable and is
# regenerated by vamp_enclosure.py — track it so it can be sent to a fabricator.
# build_step() emits vamp_assembly/faceplate/platform .step — those are tracked.

# quote / RFQ scratch: per-vendor bundles + ad-hoc per-part folded STEPs exported
# for instant-quote fabs. NOT produced by vamp_enclosure.py, so not part of the
# tracked deliverable — regenerate per quote instead.
out/quote_pkg/
out/vamp_sheetmetal/
out/vamp_sheetmetal_step/
out/*.zip
out/vamp_base.step
out/vamp_corner_bracket_rear.step
out/vamp_platform_front.step
out/vamp_platform_mid.step
out/vamp_rear_panel_pi.step
out/vamp_ring_disc.step
out/vamp_screen_bracket.step

# scratch scripts
_*.py
out/vamp.glb
out/vamp.gltf
out/vamp.bin
out/vamp_fromdxf.glb
out/viewer.html
out/index.html
out/loopy_pedal_main.glb
out/raspberry_pi4.glb
out/loopy_pedal_tht.glb
