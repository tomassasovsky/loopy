	(pad "1" thru_hole circle (at 3.85 7.5) (size 2 2) (drill 1.3) (layers "*.Cu" "*.Mask"))
	(pad "2" thru_hole circle (at 3.85 0) (size 2 2) (drill 1.3) (layers "*.Cu" "*.Mask"))
