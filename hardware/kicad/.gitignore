# SKiDL/KiCad transient reports + symbol caches
*.erc
*_sklib.py
*.log

# KiCad local prefs / locks / backups
*.kicad_prl
*.lck
*-backups/

# Routing intermediates (regenerated by the layout pipeline)
*.dsn
*.ses

# Layout pipeline scripts (use absolute local paths; not portable)
_*.py
_*.sh

# Render / preview artifacts
_*.png
_*.svg
_*.txt
_*.rpt
*-drc.rpt

# OpenSCAD intermediate (the .wrl it produces is committed; .scad is the source)
*.stl

# Freerouting jar + raw gerber output (zips are committed)
_tools/
fab/loopy_pedal_main/
fab/loopy_pedal_ring/
fab/loopy_pi_main/

# Pi-on-board 3D assembly: generated board + downloaded Pi model (render-only,
# pi_assemble.py fetches the model on demand)
_assembly.*
_models/

# Throwaway test boards / KiCad caches
_*.kicad_pcb
_*.kicad_pro
fp-info-cache

# Stray single-board gerber/drill exports in the kicad root (the committed
# deliverable is fab/*.zip; these loose files are scratch from ad-hoc exports)
/loopy_pedal_*-*.gbr
/loopy_pedal_*-*.gbrjob
/gerbers/
*-drc.rpt
