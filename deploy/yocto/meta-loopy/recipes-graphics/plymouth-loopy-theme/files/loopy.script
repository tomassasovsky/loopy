# Loopy floor-console boot splash. The segno lockup (Bravura mark + Apple Chancery
# "segno" wordmark, pre-rendered from the smooth glyph vectors) centred on the
# console near-black (#08080A), with a gentle luminance shimmer and a determinate
# progress bar driven by the real boot progress. No breathe, no text banners, no
# Pi rainbow.

Window.SetBackgroundTopColor(0.031, 0.031, 0.039);
Window.SetBackgroundBottomColor(0.031, 0.031, 0.039);
sw = Window.GetWidth();
sh = Window.GetHeight();

lockup.image = Image("loopy-lockup.png");
lockup.sprite = Sprite();
lockup.sprite.SetImage(lockup.image);
lockup.sprite.SetX((sw - lockup.image.GetWidth()) / 2);
lockup.sprite.SetY((sh - lockup.image.GetHeight()) / 2 - sh * 0.04);
lockup.sprite.SetZ(10);

# --- progress bar (hairline track + fill) ---
bar.pixel = Image("loopy-bar-pixel.png");
bar.w = Math.Int(sw * 0.20);
bar.h = 3;
bar.x = Math.Int((sw - bar.w) / 2);
bar.y = Math.Int(sh * 0.86);
bar.track = Sprite();
bar.track.SetImage(bar.pixel.Scale(bar.w, bar.h));
bar.track.SetX(bar.x);
bar.track.SetY(bar.y);
bar.track.SetOpacity(0.10);
bar.track.SetZ(8);
bar.fill = Sprite();
bar.fill.SetZ(9);
bar.progress = 0;

tick = 0;
fun refresh_cb() {
    tick++;
    # shimmer: slow luminance pulse (~2.8s) on the lockup
    lockup.sprite.SetOpacity(0.86 + 0.14 * Math.Sin(tick * 0.045));
    # progress fill
    fw = Math.Int(bar.w * bar.progress);
    if (fw < 2) fw = 2;
    bar.fill.SetImage(bar.pixel.Scale(fw, bar.h));
    bar.fill.SetX(bar.x);
    bar.fill.SetY(bar.y);
    bar.fill.SetOpacity(0.95);
}
Plymouth.SetRefreshFunction(refresh_cb);

fun progress_cb(duration, progress) {
    bar.progress = progress;
}
Plymouth.SetBootProgressFunction(progress_cb);

fun quit_cb() {
    lockup.sprite.SetOpacity(0);
    bar.track.SetOpacity(0);
    bar.fill.SetOpacity(0);
}
Plymouth.SetQuitFunction(quit_cb);
