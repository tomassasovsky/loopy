#!/bin/sh
# Launch the prebuilt Loopy GTK bundle as a Wayland client under weston.
# GDK_BACKEND=wayland forces the GTK embedder onto Wayland (not X11/XWayland).
# LOOPY_CONSOLE is already compiled into the bundle; nothing to pass here.
export GDK_BACKEND=wayland

# The service runs as root; path_provider (session/export dirs) needs HOME + XDG
# set or it throws MissingPlatformDirectoryException. Create + point them.
export HOME="${HOME:-/root}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
mkdir -p "$XDG_DATA_HOME" "$XDG_CONFIG_HOME"

# path_provider's getApplicationDocumentsDirectory shells out to `xdg-user-dir
# DOCUMENTS` (xdg-user-dirs package). On this minimal image there is no
# user-dirs.dirs, so without seeding one the lookup fails and the app throws
# MissingPlatformDirectoryException on startup. Seed a default (idempotent) and
# create the dirs so session import/export land under ~/Documents. Validated on
# device: with the xdg-user-dir binary + this file the startup exception is gone.
if [ ! -f "$XDG_CONFIG_HOME/user-dirs.dirs" ]; then
  cat > "$XDG_CONFIG_HOME/user-dirs.dirs" <<'EOF'
XDG_DESKTOP_DIR="$HOME/Desktop"
XDG_DOCUMENTS_DIR="$HOME/Documents"
XDG_DOWNLOAD_DIR="$HOME/Downloads"
XDG_MUSIC_DIR="$HOME/Documents"
XDG_PICTURES_DIR="$HOME/Documents"
XDG_PUBLICSHARE_DIR="$HOME/Documents"
XDG_TEMPLATES_DIR="$HOME/Documents"
XDG_VIDEOS_DIR="$HOME/Documents"
EOF
fi
mkdir -p "$HOME/Documents" "$HOME/Downloads" "$HOME/Desktop"

# Audio: DIRECT ALSA. This appliance owns the sound card, so LOOPY_ALSA_ONLY tells
# the engine to force miniaudio's ALSA backend (lowest latency, zero IPC) instead
# of the desktop JACK->pulse->alsa preference. No PipeWire/JACK in the image, so no
# pw-jack shim. Runtime rate/buffer changes are safe (the ALSA-duplex uninit
# deadlock is fixed in the engine). The audio thread self-promotes to SCHED_FIFO;
# that needs the RT limits on loopy.service.
export LOOPY_ALSA_ONLY=1
exec /opt/loopy/loopy "$@"
